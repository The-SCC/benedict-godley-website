<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Benedict Godley | Client-Generating Websites</title>

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: Inter, Arial, sans-serif;
      background: #050816;
      color: #ffffff;
      line-height: 1.6;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background:
        radial-gradient(circle at 20% 20%, rgba(37,99,235,.35), transparent 30%),
        radial-gradient(circle at 80% 10%, rgba(14,165,233,.25), transparent 30%),
        radial-gradient(circle at 50% 90%, rgba(59,130,246,.18), transparent 35%);
      z-index: -2;
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      background-image: linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: linear-gradient(to bottom, black, transparent);
      z-index: -1;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .container {
      width: 92%;
      max-width: 1180px;
      margin: auto;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(18px);
      background: rgba(5, 8, 22, 0.72);
      border-bottom: 1px solid rgba(255,255,255,.08);
    }

    nav {
      min-height: 78px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      font-weight: 900;
      letter-spacing: -0.04em;
      font-size: 22px;
    }

    .logo span {
      color: #60a5fa;
    }

    .nav-links {
      display: flex;
      gap: 26px;
      color: #cbd5e1;
      font-size: 14px;
    }

    .nav-links a:hover {
      color: #ffffff;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: linear-gradient(135deg, #2563eb, #06b6d4);
      color: white;
      padding: 15px 24px;
      border-radius: 999px;
      font-weight: 800;
      box-shadow: 0 18px 45px rgba(37,99,235,.35);
      transition: .25s ease;
    }

    .btn:hover {
      transform: translateY(-3px) scale(1.02);
      box-shadow: 0 24px 70px rgba(37,99,235,.48);
    }

    .btn.secondary {
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.14);
      box-shadow: none;
      color: #e5e7eb;
    }

    .hero {
      padding: 110px 0 85px;
      position: relative;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.05fr .95fr;
      gap: 56px;
      align-items: center;
    }

    .badge {
      display: inline-flex;
      padding: 9px 14px;
      border-radius: 999px;
      background: rgba(96,165,250,.12);
      border: 1px solid rgba(96,165,250,.28);
      color: #bfdbfe;
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 22px;
    }

    h1 {
      font-size: clamp(44px, 7vw, 82px);
      line-height: .95;
      letter-spacing: -0.07em;
      margin-bottom: 26px;
    }

    .gradient-text {
      background: linear-gradient(135deg, #ffffff, #93c5fd, #22d3ee);
      -webkit-background-clip: text;
      color: transparent;
    }

    .hero p {
      font-size: 20px;
      color: #cbd5e1;
      max-width: 650px;
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 32px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-top: 42px;
    }

    .stat {
      background: rgba(255,255,255,.07);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 18px;
      padding: 18px;
    }

    .stat strong {
      font-size: 28px;
      display: block;
    }

    .stat span {
      color: #94a3b8;
      font-size: 13px;
    }

    .dashboard {
      position: relative;
      border-radius: 28px;
      padding: 22px;
      background: linear-gradient(145deg, rgba(255,255,255,.16), rgba(255,255,255,.05));
      border: 1px solid rgba(255,255,255,.16);
      box-shadow: 0 35px 100px rgba(0,0,0,.35);
      animation: float 5s ease-in-out infinite;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-14px); }
    }

    .screen {
      background: #020617;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.08);
    }

    .screen-top {
      display: flex;
      gap: 8px;
      padding: 16px;
      background: rgba(255,255,255,.05);
      border-bottom: 1px solid rgba(255,255,255,.08);
    }

    .dot {
      width: 11px;
      height: 11px;
      border-radius: 50%;
      background: #ef4444;
    }

    .dot:nth-child(2) { background: #f59e0b; }
    .dot:nth-child(3) { background: #22c55e; }

    .screen-body {
      padding: 24px;
    }

    .metric {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px;
      border-radius: 16px;
      background: rgba(255,255,255,.05);
      margin-bottom: 14px;
    }

    .metric span {
      color: #94a3b8;
    }

    .metric strong {
      color: #67e8f9;
      font-size: 22px;
    }

    .bar {
      height: 10px;
      background: rgba(255,255,255,.08);
      border-radius: 999px;
      overflow: hidden;
      margin: 18px 0;
    }

    .bar div {
      height: 100%;
      width: 76%;
      background: linear-gradient(90deg, #2563eb, #06b6d4);
      border-radius: inherit;
      animation: grow 1.6s ease forwards;
    }

    @keyframes grow {
      from { width: 0; }
      to { width: 76%; }
    }

    .mini-card {
      padding: 18px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(37,99,235,.25), rgba(6,182,212,.15));
      border: 1px solid rgba(255,255,255,.1);
    }

    section {
      padding: 86px 0;
    }

    .section-head {
      max-width: 760px;
      margin-bottom: 42px;
    }

    .section-head h2 {
      font-size: clamp(34px, 5vw, 56px);
      line-height: 1;
      letter-spacing: -0.05em;
      margin-bottom: 16px;
    }

    .section-head p {
      color: #94a3b8;
      font-size: 18px;
    }

    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .card {
      position: relative;
      padding: 28px;
      border-radius: 24px;
      background: rgba(255,255,255,.07);
      border: 1px solid rgba(255,255,255,.1);
      transition: .25s ease;
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top right, rgba(96,165,250,.25), transparent 35%);
      opacity: 0;
      transition: .25s ease;
    }

    .card:hover {
      transform: translateY(-8px);
      border-color: rgba(96,165,250,.4);
    }

    .card:hover::before {
      opacity: 1;
    }

    .card h3,
    .card p,
    .card ul {
      position: relative;
      z-index: 1;
    }

    .card h3 {
      font-size: 23px;
      margin-bottom: 12px;
    }

    .card p,
    .card li {
      color: #cbd5e1;
    }

    .card ul {
      list-style: none;
      margin-top: 18px;
    }

    .card li {
      margin-bottom: 10px;
    }

    .problem .card {
      border-left: 4px solid #ef4444;
    }

    .solution {
      background: rgba(255,255,255,.03);
    }

    .steps {
      counter-reset: step;
    }

    .step::after {
      counter-increment: step;
      content: "0" counter(step);
      position: absolute;
      top: 18px;
      right: 22px;
      color: rgba(255,255,255,.12);
      font-size: 52px;
      font-weight: 900;
    }

    .testimonial {
      min-height: 250px;
    }

    .testimonial strong {
      display: block;
      margin-top: 22px;
      color: #ffffff;
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: 1fr 1.15fr;
      gap: 24px;
      align-items: stretch;
    }

    .price-card {
      padding: 34px;
      border-radius: 28px;
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.12);
    }

    .price-card.featured {
      background: linear-gradient(145deg, rgba(37,99,235,.38), rgba(6,182,212,.16));
      border-color: rgba(96,165,250,.45);
      box-shadow: 0 30px 90px rgba(37,99,235,.22);
    }

    .price {
      font-size: 46px;
      font-weight: 900;
      margin: 18px 0;
      letter-spacing: -0.05em;
    }

    .price-card ul {
      margin: 24px 0;
      padding-left: 20px;
      color: #cbd5e1;
    }

    .price-card li {
      margin-bottom: 12px;
    }

    .cta {
      text-align: center;
      padding: 100px 20px;
      background:
        radial-gradient(circle at 50% 0%, rgba(37,99,235,.45), transparent 35%),
        linear-gradient(135deg, rgba(37,99,235,.35), rgba(6,182,212,.08));
    }

    .cta h2 {
      font-size: clamp(38px, 6vw, 68px);
      line-height: 1;
      letter-spacing: -0.06em;
      max-width: 900px;
      margin: auto;
    }

    .cta p {
      color: #dbeafe;
      margin: 22px auto 0;
      max-width: 650px;
      font-size: 19px;
    }

    footer {
      border-top: 1px solid rgba(255,255,255,.08);
      padding: 28px 0;
      color: #94a3b8;
      text-align: center;
    }

    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: .7s ease;
    }

    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    @media (max-width: 850px) {
      .hero-grid,
      .grid-3,
      .pricing-grid {
        grid-template-columns: 1fr;
      }

      .nav-links {
        display: none;
      }

      .hero {
        padding: 72px 0 56px;
      }

      section {
        padding: 64px 0;
      }

      .stats {
        grid-template-columns: 1fr;
      }

      .dashboard {
        animation: none;
      }
    }
  </style>
</head>

